    <!-- Step boxes -->
    <mxCell id="step0" value="INPUT&#xa;cable_p1, cable_p2, n_crossings&#xa;angle_deg, turn_sharpness&#xa;drone_speed, sampling_freq" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;fontSize=11;fontStyle=1;" vertex="1" parent="1">
