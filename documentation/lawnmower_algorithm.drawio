      </mxGeometry>
    </mxCell>

    <mxCell id="step1" value="1. Build cable frame&#xa;u_along = (P2−P1) / |P2−P1|&#xa;u_perp  = rotate u_along 90° CCW" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="610" y="220" width="280" height="60" as="geometry" />
    </mxCell>

    <mxCell id="step1_arrow" value="" style="endArrow=block;endFill=1;html=1;strokeColor=#388E3C;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="750" y="280" as="sourcePoint" />
        <mxPoint x="750" y="305" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <mxCell id="step2" value="2. Compute cross_dir&#xa;cross_dir = sin(θ)·u_perp + cos(θ)·u_along&#xa;(travel direction of each pass)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="610" y="305" width="280" height="60" as="geometry" />
    </mxCell>

    <mxCell id="step2_arrow" value="" style="endArrow=block;endFill=1;html=1;strokeColor=#388E3C;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="750" y="365" as="sourcePoint" />
        <mxPoint x="750" y="390" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <mxCell id="step3" value="3. Place N anchors along cable&#xa;offset_i = i × cable_len / (N−1)&#xa;anchor_i = P1 + offset_i × u_along" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="610" y="390" width="280" height="60" as="geometry" />
    </mxCell>

    <mxCell id="step3_arrow" value="" style="endArrow=block;endFill=1;html=1;strokeColor=#388E3C;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="750" y="450" as="sourcePoint" />
        <mxPoint x="750" y="475" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <mxCell id="step4" value="4. For each anchor i:&#xa;  direction = cross_dir  (i even)&#xa;             −cross_dir  (i odd)&#xa;  pass: anchor ± pass_half × direction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="610" y="475" width="280" height="70" as="geometry" />
    </mxCell>

    <mxCell id="step4_arrow" value="" style="endArrow=block;endFill=1;html=1;strokeColor=#388E3C;strokeWidth=2;" edge="1" parent="1">
      <mxGeometry relative="1" as="geometry">
        <mxPoint x="750" y="545" as="sourcePoint" />
        <mxPoint x="750" y="570" as="targetPoint" />
      </mxGeometry>
    </mxCell>

    <mxCell id="step5" value="5. Between passes: circular arc&#xa;  r = (spacing/2) / turn_sharpness&#xa;  outward = lateral(anchor − prev_end)&#xa;  arc: tangent-in=prev_dir, tangent-out=direction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
      <mxGeometry x="610" y="570" width="280" height="70" as="geometry" />
