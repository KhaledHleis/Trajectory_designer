    <mxCell id="tangent_note" value="Tangent continuity guaranteed:&#xa;• Arc departs tangent to dir_in&#xa;• Arc arrives tangent to dir_out&#xa;• No kink at transition" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8BBD0;strokeColor=#C2185B;fontSize=11;align=left;" vertex="1" parent="1">
      <mxGeometry x="960" y="370" width="320" height="80" as="geometry" />
    </mxCell>

    <!-- tangent math -->
    <mxCell id="tangent_math" value="CCW orbit:  tangent(a) = (−sin a, cos a)&#xa;  → a₁ = atan2(−dₓ, d_y)&#xa;&#xa;CW  orbit:  tangent(a) = ( sin a, −cos a)&#xa;  → a₁ = atan2( dₓ, −d_y)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#880E4F;fontSize=11;fontStyle=2;align=left;" vertex="1" parent="1">
      <mxGeometry x="960" y="465" width="320" height="90" as="geometry" />
    </mxCell>

    <!-- outward side note -->
    <mxCell id="outward_note" value="Outward side selection:&#xa;  to_next = anchor − prev_end&#xa;  lateral = to_next − (to_next·dir_in)·dir_in&#xa;  outward = lateral / |lateral|&#xa;→ always curves AWAY from cable interior" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FCE4EC;strokeColor=#880E4F;fontSize=11;align=left;" vertex="1" parent="1">
      <mxGeometry x="960" y="565" width="320" height="90" as="geometry" />
    </mxCell>

